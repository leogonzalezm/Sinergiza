---
interface Props {
  step: string;
  title: string;
  description: string;
  isLast?: boolean;
}

const { step, title, description, isLast = false } = Astro.props;
---

<div class="flex gap-6">
  <div class="flex flex-col items-center">
    <div class="chip-muted w-11 px-0 text-center shrink-0">
      {step}
    </div>
    {!isLast && (
      <div class="w-px flex-1 bg-border mt-2"></div>
    )}
  </div>

  <div class:list={['pb-10', isLast && 'pb-0']}>
    <h3 class="text-h4 font-heading font-semibold mb-1">{title}</h3>
    <p class="text-small text-slate leading-relaxed">{description}</p>
  </div>
</div>

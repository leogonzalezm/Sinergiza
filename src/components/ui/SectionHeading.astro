---
interface Props {
  label: string;
  eyebrow?: string;
  class?: string;
}

const { label, eyebrow, class: className } = Astro.props;
---

<div class:list={['mb-8', className]}>
  {eyebrow && (
    <span class="block text-xs font-semibold uppercase tracking-widest text-signal mb-3">
      {eyebrow}
    </span>
  )}
  <h2 class="text-h2 md:text-h1 font-heading font-bold text-balance">
    {label}
  </h2>
</div>

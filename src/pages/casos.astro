---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import FadeIn from '../components/motion/FadeIn.tsx';
import { getCases } from '../lib/wordpress';

const cases = await getCases();
---

<Layout title="Casos" description="Ejemplos del tipo de soluciones digitales que diseñamos y desarrollamos en Sinergiza.">
  <Header slot="header" />

  <section class="pt-12 pb-12 bg-ivory">
    <div class="container-narrow">
      <FadeIn client:load>
        <SectionHeading eyebrow="Casos" label="Ejemplos del tipo de soluciones que solemos construir" />
        <p class="text-body-lg text-slate max-w-2xl -mt-4">
          Estos casos muestran formatos de proyecto representativos. El objetivo es que puedas reconocer patrones, complejidad y tipo de enfoque antes de conversar.
        </p>
      </FadeIn>
    </div>
  </section>

  <section class="pb-[var(--spacing-section)]">
    <div class="container-narrow space-y-6">
      {cases.length > 0 ? (
        cases.map((item, index) => (
          <FadeIn client:load delay={index * 0.07}>
            <article class="p-8 surface-box">
              <div class="flex items-center gap-3 mb-3">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-signal">{item.stack}</p>
                {item.industry && <span class="chip-muted text-xs">{item.industry}</span>}
              </div>
              {item.coverImage?.url && (
                <div class="aspect-[16/9] overflow-hidden rounded-[var(--radius-lg)] mb-5">
                  <img src={item.coverImage.url} alt={item.coverImage.alt || item.title} class="w-full h-full object-cover" loading="lazy" />
                </div>
              )}
              <h2 class="text-h3 font-heading font-semibold mb-4">{item.title}</h2>
              <p class="text-body text-slate leading-relaxed mb-3"><strong class="text-carbon">Desafío:</strong> {item.challenge}</p>
              <p class="text-body text-slate leading-relaxed mb-3"><strong class="text-carbon">Solución:</strong> {item.solution}</p>
              {item.result && <p class="text-body text-slate leading-relaxed mb-3"><strong class="text-carbon">Resultado:</strong> {item.result}</p>}
              {item.projectUrl && (
                <a href={item.projectUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-signal text-small font-medium hover:underline mt-2">
                  Ver proyecto →
                </a>
              )}
            </article>
          </FadeIn>
        ))
      ) : (
        <div class="p-8 surface-box text-center">
          <p class="text-body text-slate">Próximamente publicaremos casos de ejemplo.</p>
        </div>
      )}
    </div>
  </section>

  <section class="section-padding bg-signal text-white">
    <div class="container-narrow text-center">
      <FadeIn client:load>
        <h2 class="text-h2 font-heading font-bold text-white mb-4">¿Tu caso se parece a alguno de estos?</h2>
        <p class="text-body-lg text-white/80 max-w-xl mx-auto mb-8">
          Si reconoces el patrón, probablemente podemos ayudarte a definir la mejor ruta de implementación.
        </p>
        <a href="/contacto" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-signal font-semibold rounded-[var(--radius-lg)] hover:bg-ivory transition-colors">
          Agendar diagnóstico
        </a>
      </FadeIn>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
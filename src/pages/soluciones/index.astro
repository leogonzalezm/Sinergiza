---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import FadeIn from '../../components/motion/FadeIn.tsx';

const icons = {
  APP: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
  AI: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>',
  API: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m16 3 4 4-4 4"/><path d="M20 7H4"/><path d="m8 21-4-4 4-4"/><path d="M4 17h16"/></svg>',
  ECM: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>',
  UX: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>',
  OPS: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/></svg>',
};

const solutions = [
  {
    icon: icons.APP,
    title: 'Desarrollo a medida',
    description: 'Aplicaciones web, plataformas internas, dashboards y portales con lógica de negocio propia. Construimos desde cero con el stack óptimo para tu caso.',
    href: '/soluciones/desarrollo-a-medida',
    examples: ['Portales con roles y permisos', 'Dashboards operativos', 'APIs y microservicios', 'Aplicaciones SaaS'],
  },
  {
    icon: icons.AI,
    title: 'IA aplicada',
    description: 'Integramos inteligencia artificial para resolver problemas concretos de tu operación: automatización, análisis, atención y toma de decisiones.',
    href: '/soluciones/ia-aplicada',
    examples: ['Chatbots con base de conocimiento', 'Automatización documental', 'Clasificación y extracción de datos', 'Copilotos operativos'],
  },
  {
    icon: icons.API,
    title: 'Integraciones y automatización',
    description: 'Conectamos los sistemas que ya usas y eliminamos procesos manuales repetitivos con flujos automatizados.',
    href: '/soluciones/integraciones',
    examples: ['CRM ↔ ERP ↔ Web', 'Pasarelas de pago', 'Webhooks y APIs de terceros', 'Flujos Zapier / Make'],
  },
  {
    icon: icons.ECM,
    title: 'Ecommerce y plataformas',
    description: 'Tiendas online y marketplaces con foco en conversión, rendimiento y experiencia de compra.',
    href: '/soluciones/ecommerce',
    examples: ['WooCommerce optimizado', 'Ecommerce headless', 'Catálogos B2B', 'Marketplaces multi-vendor'],
  },
  {
    icon: icons.UX,
    title: 'Diseño UX/UI',
    description: 'Interfaces claras, rápidas y orientadas a resultados. Diseño centrado en el usuario y en los objetivos de negocio.',
    href: '/soluciones/ux-ui',
    examples: ['Diseño de producto digital', 'Rediseño de interfaces', 'Sistemas de diseño', 'Prototipado interactivo'],
  },
  {
    icon: icons.OPS,
    title: 'Evolución continua',
    description: 'Tu solución no se detiene en el lanzamiento. Soporte, optimización, nuevas funcionalidades y monitoreo permanente.',
    href: '/soluciones/evolucion-continua',
    examples: ['Soporte técnico mensual', 'Optimización de rendimiento', 'Nuevas features iterativas', 'Monitoreo y alertas'],
  },
];
---

<Layout title="Soluciones" description="Desarrollo a medida, IA aplicada, integraciones, ecommerce y diseño UX/UI. Elegimos la tecnología según tu problema, no al revés.">
  <Header slot="header" />

  <!-- Hero -->
  <section class="pt-12 pb-12 bg-ivory">
    <div class="container-narrow">
      <FadeIn client:load>
        <div class="max-w-3xl">
          <SectionHeading
            eyebrow="Soluciones"
            label="Cada problema de negocio tiene su solución tecnológica"
          />
          <p class="text-body-lg text-slate max-w-2xl -mt-4">
            No vendemos herramientas. Analizamos tu desafío, elegimos el enfoque
            correcto y construimos la solución que tu empresa necesita para crecer.
          </p>
        </div>
      </FadeIn>
    </div>
  </section>

  <!-- Solutions Grid -->
  <section class="pb-[var(--spacing-section)]">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {solutions.map((sol, i) => (
          <FadeIn client:load delay={i * 0.06}>
            <a href={sol.href} class="group block p-8 surface-box hover:shadow-lg transition-all duration-[var(--duration-normal)] ease-[var(--ease-out)] hover:-translate-y-0.5">
              <div class="w-10 h-10 mb-4 flex items-center justify-center rounded-[var(--radius-lg)] bg-signal/8 text-signal" set:html={sol.icon} />
              <h3 class="text-h3 font-heading font-semibold mb-3 group-hover:text-signal transition-colors">
                {sol.title}
              </h3>
              <p class="text-body text-slate leading-relaxed mb-5">
                {sol.description}
              </p>
              <ul class="flex flex-wrap gap-2">
                {sol.examples.map((ex) => (
                  <li class="chip">
                    {ex}
                  </li>
                ))}
              </ul>
            </a>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-signal text-white">
    <div class="container-narrow text-center">
      <FadeIn client:load>
        <h2 class="text-h2 font-heading font-bold text-white mb-4 text-balance">
          ¿No sabes cuál es la solución correcta para tu caso?
        </h2>
        <p class="text-body-lg text-white/80 max-w-xl mx-auto mb-8">
          Es normal. Para eso existe nuestro diagnóstico gratuito: analizamos
          tu situación y te recomendamos el enfoque adecuado sin compromiso.
        </p>
        <a
          href="/contacto"
          class="inline-flex items-center gap-2 px-6 py-3 bg-white text-signal font-semibold rounded-[var(--radius-lg)] hover:bg-ivory transition-colors"
        >
          Agendar diagnóstico gratuito
        </a>
      </FadeIn>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
